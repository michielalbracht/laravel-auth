{
    "name": "albrachtsystems/laravel-auth",
    "description": "Herbruikbare authenticatiemodule voor Laravel: Sanctum-tokens, passkeys, e-mailverificatie en -wijziging, wachtwoordherstel en profiel.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^13.0",
        "laravel/sanctum": "^4.3",
        "laravel/passkeys": "^0.2.1",
        "intervention/image-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "AlbrachtSystems\\Auth\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AlbrachtSystems\\Auth\\AuthServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
